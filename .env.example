# Dual-provider selection:
# 1. OPENAI_API_KEY when present, unless AI_PROVIDER=openrouter.
# 2. OPENROUTER_API_KEY when no OpenAI key is present.
# 3. Deterministic fallbacks when neither key is present.
# AI_PROVIDER=openrouter

# Free path: create a key at https://openrouter.ai/keys.
OPENROUTER_API_KEY=

# OpenAI's open-weight 120B reasoning model, served free through OpenRouter.
OPENROUTER_MODEL=openai/gpt-oss-120b:free
# OPENROUTER_BRIEFING_MODEL=openai/gpt-oss-120b:free
# OPENROUTER_CONSEQUENCE_MODEL=openai/gpt-oss-120b:free
# OPENROUTER_MINOR_MODEL=openai/gpt-oss-120b:free
# OPENROUTER_SITE_URL=http://localhost:5173

# Paid future path: paste an OpenAI API key whenever funding is available.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
# OPENAI_BRIEFING_MODEL=gpt-5.6
# OPENAI_CONSEQUENCE_MODEL=gpt-5.6
# OPENAI_MINOR_MODEL=gpt-5.6-luna

# Hard-capped at 200 by the server even if a larger value is configured.
OPENROUTER_DAILY_CALL_LIMIT=200

# Optional persistent cache/counter location. Defaults to .state-of-play locally.
# OPENROUTER_RUNTIME_FILE=

# Server-side only. Used by /api/news; seed headlines are served when omitted.
SERPAPI_KEY=
