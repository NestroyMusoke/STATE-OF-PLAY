# Server-side only. Leave blank to run entirely on deterministic fallbacks.
OPENAI_API_KEY=

# Optional overrides. These defaults are used when the variables are omitted.
OPENAI_BRIEFING_MODEL=gpt-5.6
OPENAI_CONSEQUENCE_MODEL=gpt-5.6
OPENAI_MINOR_MODEL=gpt-5.6-luna

# Hard-capped at 200 by the server even if a larger value is configured.
OPENAI_DAILY_CALL_LIMIT=200

# Optional persistent cache/counter location. Defaults to .state-of-play locally.
# OPENAI_RUNTIME_FILE=

# Server-side only. Used by /api/news; seed headlines are served when omitted.
SERPAPI_KEY=
